        <category>技术分享</category>
      </categories>
      <tags>
        <tag>Linux</tag>
        <tag>我的世界</tag>
        <tag>Minecraft</tag>
        <tag>MC</tag>
        <tag>我的世界服务器</tag>
      </tags>
